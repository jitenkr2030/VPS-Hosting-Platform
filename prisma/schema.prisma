// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?
  role          Role     @default(USER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // VPS instances owned by this user
  vpsInstances  VpsInstance[]
  
  // NextAuth.js accounts
  accounts      Account[]
  sessions      Session[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model VpsInstance {
  id          String     @id @default(cuid())
  name        String
  hostname    String
  status      VpsStatus  @default(PENDING)
  plan        VpsPlan
  cpu         Int
  ram         Int // in GB
  storage     Int // in GB
  bandwidth   Int // in GB
  price       Float // monthly price
  ipAddresses String // JSON string array of IP addresses
  os          String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  expiresAt   DateTime
  userId      String
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("vps_instances")
}

model VpsTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  os          String
  version     String
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("vps_templates")
}

enum Role {
  USER
  ADMIN
}

enum VpsStatus {
  PENDING
  ACTIVE
  SUSPENDED
  TERMINATED
  ERROR
}

enum VpsPlan {
  STARTER
  PROFESSIONAL
  BUSINESS
}